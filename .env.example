# === Docker 部署（推荐，用户零配置）===
# docker-compose up -d 即可，无需修改此文件

# cobalt 内置服务地址（docker-compose 自动设置，无需手动改）
# COBALT_API_URL=http://cobalt:9000
# COBALT_ENABLED=true

# === 可选调优 ===
# 下载文件目录
# DOWNLOAD_DIR=/app/data/downloads

# 任务文件保留时间（秒）
JOB_TTL_SECONDS=86400

# 解析 / 下载超时（秒）
RESOLVE_TIMEOUT=120
DOWNLOAD_TIMEOUT=3600
